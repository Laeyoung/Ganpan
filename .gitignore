# heartbeat pid files are written to $TMPDIR, but ignore strays just in case
hb-*.pid

# review-loop state files are machine-local bookkeeping (contain absolute paths) — never commit
docs/reviews/*.state.json
# qa-review-loop state files — same machine-local bookkeeping
docs/qa/*.state.json

# scheduled-task lock — per-session runtime state (sessionId/pid), not source
.claude/scheduled_tasks.lock

# copy-in install artifacts — this repo self-installs ganpan (install.sh) to run
# lanes on its own issues; canonical sources live under plugins/orchestration/,
# so these root copies are runtime-only and must not be tracked.
/.claude/commands/
/scripts/
/references/
/.github/labels.yml
/.github/ISSUE_TEMPLATE/task.yml
